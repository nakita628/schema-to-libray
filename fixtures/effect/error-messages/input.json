{
  "title": "User",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 20,
      "pattern": "^[a-zA-Z]+$",
      "x-error-message": "Invalid name",
      "x-pattern-message": "Only alphabetic characters",
      "x-minLength-message": "Name too short",
      "x-maxLength-message": "Name too long"
    },
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120,
      "multipleOf": 1,
      "x-error-message": "Invalid age",
      "x-minimum-message": "Age must be positive",
      "x-maximum-message": "Age too large",
      "x-multipleOf-message": "Age must be integer"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 5,
      "x-size-message": "Bad tag count",
      "x-minItems-message": "Need at least one tag",
      "x-maxItems-message": "Too many tags"
    }
  },
  "required": ["name", "age", "tags"]
}
