{
  "name": "schema-to-library",
  "version": "0.1.0",
  "description": "Generate Zod/Valibot/Effect/TypeBox/Arktype schemas from JSON or YAML files",
  "keywords": [
    "arktype",
    "effect",
    "typebox",
    "valibot",
    "zod"
  ],
  "homepage": "https://github.com/nakita628/schema-to-libray",
  "bugs": {
    "url": "https://github.com/nakita628/schema-to-libray/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakita628/schema-to-libray.git"
  },
  "bin": {
    "schema-to-arktype": "dist/cli/arktype.js",
    "schema-to-effect": "dist/cli/effect.js",
    "schema-to-typebox": "dist/cli/typebox.js",
    "schema-to-valibot": "dist/cli/valibot.js",
    "schema-to-zod": "dist/cli/zod.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "typesVersions": {
    "*": {
      "zod": [
        "./dist/zod.d.ts"
      ],
      "valibot": [
        "./dist/valibot.d.ts"
      ],
      "effect": [
        "./dist/effect.d.ts"
      ],
      "typebox": [
        "./dist/typebox.d.ts"
      ],
      "arktype": [
        "./dist/arktype.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.js"
    },
    "./valibot": {
      "types": "./dist/valibot.d.ts",
      "import": "./dist/valibot.js"
    },
    "./effect": {
      "types": "./dist/effect.d.ts",
      "import": "./dist/effect.js"
    },
    "./typebox": {
      "types": "./dist/typebox.d.ts",
      "import": "./dist/typebox.js"
    },
    "./arktype": {
      "types": "./dist/arktype.d.ts",
      "import": "./dist/arktype.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "release": "pnpm build && pnpm publish"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.1",
    "oxfmt": "^0.36.0"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "tsdown": "^0.21.0"
  }
}
